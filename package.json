{
  "name": "cardgamebuilder",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A PWA to design card games and export print-ready PDFs, entirely in the browser.",
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "build:fast": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "icons": "node scripts/gen-icons.mjs",
    "verify": "node scripts/verify.mjs",
    "test:layout": "esbuild scripts/check-layout.mts --bundle --platform=node --format=esm --outfile=.cache/check-layout.mjs && node .cache/check-layout.mjs",
    "test:e2e": "node scripts/e2e.mjs",
    "test": "npm run verify && npm run test:layout"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^22.20.1",
    "playwright-core": "^1.61.1",
    "svelte": "^5.15.0",
    "svelte-check": "^4.1.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2",
    "vite": "^7.3.6",
    "vite-plugin-pwa": "^1.0.3"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1"
  }
}
